# ─── macOS ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ─── Windows ─────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── Linux ───────────────────────────────────────────────────────
*~

# ─── Environment variables / secrets ─────────────────────────────
.env
.env.*
*.env
# Allow example/template env files
!*.env.example
!*.env.template

# ─── Node / npm ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock

# ─── Next.js (website) ───────────────────────────────────────────
.next/
/out/
/build/
*.tsbuildinfo
next-env.d.ts

# ─── Supabase ────────────────────────────────────────────────────
# supabase/.temp holds local dev state — not needed in version control
supabase/.temp/
supabase/.branches/

# ─── Certificates / keys ─────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# ─── Editor ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# ─── Vercel ──────────────────────────────────────────────────────
.vercel

# ─── Yarn ────────────────────────────────────────────────────────
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Coverage / testing ──────────────────────────────────────────
/coverage
.nyc_output

# ─── Misc ────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
