# Supabase — get these from your project at supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-only, never expose to the browser
# Required for the /admin dashboard. Get it from supabase.com → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin dashboard credentials — completely separate from Supabase auth
ADMIN_EMAIL=example@gmail.com
ADMIN_PASSWORD=pass
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-64-char-random-hex-string

# Chrome Extension ID — optional
# Find it at chrome://extensions (enable Developer Mode), copy the ID
NEXT_PUBLIC_Klokrs_EXTENSION_ID=your-extension-id-here

# ── Stripe billing ──────────────────────────────────────────────────────────
# All server-only. If unset, billing routes return a graceful "not configured".
# Get keys from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Create two recurring Products/Prices in Stripe, paste their price IDs here
STRIPE_PRICE_STANDARD=price_your-standard-price-id
STRIPE_PRICE_PRO=price_your-pro-price-id
# From the webhook endpoint you create (Developers → Webhooks → reveal signing secret)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Public base URL for Stripe success/cancel/return redirects (no trailing slash)
NEXT_PUBLIC_APP_URL=https://klokrs.com
