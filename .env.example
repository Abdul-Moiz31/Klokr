# Supabase — get these from your project at supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-only, never expose to the browser
# Required for the /admin dashboard. Get it from supabase.com → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin dashboard credentials — completely separate from Supabase auth
ADMIN_EMAIL=example@gmail.com
ADMIN_PASSWORD=pass
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-64-char-random-hex-string

# Chrome Extension ID — optional
# Find it at chrome://extensions (enable Developer Mode), copy the ID
NEXT_PUBLIC_Klokrs_EXTENSION_ID=your-extension-id-here

# Anthropic API key — server-only, optional fallback for users with an
# Anthropic key on file but no BYOK row (legacy). If unset, falls through.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Gemini API key — server-only, optional. NOTE: Gemini's free tier is region-
# gated (returns 429 "limit: 0" in unsupported countries) — Groq is the
# default free-tier fallback instead (see GROQ_API_KEY below).
GEMINI_API_KEY=your-gemini-key-here

# Groq API key — server-only, powers the "Ask your time" AI feature for free
# users who haven't added their own key (5 questions/month, see AI_MONTHLY_LIMIT
# in lib/ai-quota.ts). Free tier, no region/billing gating. Get it free from
# console.groq.com/keys. If unset, the feature returns a graceful "not
# configured" message instead of erroring.
GROQ_API_KEY=gsk_your-groq-key-here

# Secret used to encrypt users' own (BYOK) provider keys at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32. Required for the "use your own key" feature.
AI_KEY_ENCRYPTION_SECRET=replace-with-64-char-random-hex-string
# ── Stripe billing ──────────────────────────────────────────────────────────
# All server-only. If unset, billing routes return a graceful "not configured".
# Get keys from dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your-secret-key
# Create two recurring Products/Prices in Stripe, paste their price IDs here
STRIPE_PRICE_STANDARD=price_your-standard-price-id
STRIPE_PRICE_PRO=price_your-pro-price-id
# From the webhook endpoint you create (Developers → Webhooks → reveal signing secret)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# Public base URL for Stripe success/cancel/return redirects (no trailing slash)
NEXT_PUBLIC_APP_URL=https://klokrs.com

# ── Web Push ────────────────────────────────────────────────────────────────
# Lets a notification reach a user even with no klokrs.com tab open —
# separate from the Chrome extension's own chrome.notifications and the
# in-app bell, neither of which can. Generate a keypair with:
#   npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY must match VAPID_PUBLIC_KEY exactly (the
# public key is safe to expose to the client — that's what "public" means
# here; VAPID_PRIVATE_KEY must never be).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@klokrs.com

# Shared secret for app/api/cron/notifications — Vercel Cron sends this
# automatically as "Authorization: Bearer $CRON_SECRET" when this env var is
# set (see vercel.json). Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-64-char-random-hex-string
